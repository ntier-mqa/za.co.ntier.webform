<?xml version="1.0" encoding="UTF-8"?>
<!-- This ZUL file is designed to be included within another ZUL page. The 
	<zk> root tag has been removed. A unique 'sclass' (employer-mvvm-form) has 
	been added to the root <window> to scope the CSS rules specifically to this 
	MVVM form. -->
<?import za.co.ntier.webform.form.WebForm ?>
<?taglib uri="http://www.zkoss.org/dsp/web/core" prefix="c"?>


<zk xmlns:n="native">
<div sclass="test" style="height:100%"
		viewModel="@id('vm') @init('za.co.ntier.webform.form.viewmodel.TestVM')">
	
	<include companyInfo="@load(vm.companyInfo)"
		src="@load((WebForm.getBundleResourcePath('fragment/companyHeader.zul')))" />

	<label sclass="formHeader" value="@init(vm.formInfo.formHeader)" />
	
	<tabbox width="100%" vflex="1">
	    <tabs>
	        <tab label="Declaration" />
	        <tab label="General Application Rules" />
	        <tab label="Organisation Information" />
	        <tab label="Program" />
	        <tab label="Program Contact" />
	    </tabs>
	    <tabpanels>
	        <tabpanel style="color:#336699;">
	        	<n:p>I declare that as the duly authorised representative of the Organisation confirms that Organisation will comply with the general rules and criteria hereunder and further confirmed that all the information provided in this application is true and accurate</n:p>
	        	
	        	<div sclass="grid-container">
	        		<div sclass="form-field">
	        			<label sclass="label" value="Name and Surname"/>
	        			<textbox placeholder="Le Quy Hiep"/>
	        		</div>
	        		<div sclass="form-field">
	        			<label sclass="label" value="Date"/>
				  		<datebox />
	        		</div>
	        		<div sclass="form-field">
	        			
	        			<checkbox label="Click here to acknowledge commitment"/>
	        		</div>
	        	</div>
	        	
	        </tabpanel>
	        <tabpanel style="color:#333399;overflow: scroll;">
	        	<include menuContextInfo="@load(vm.menuContextInfo)"
					src="@load((WebForm.getBundleResourcePath('fragment/test/generalAppRule.zul')))" />
	        </tabpanel>
	        <tabpanel style="color:#663366;overflow: scroll;">
	        	<include 
	        		menuContextInfo="@load(vm.menuContextInfo)"
	        		organisationInfo="@load(vm.organisationInfo)"
					src="@load((WebForm.getBundleResourcePath('fragment/test/organisationInfo.zul')))" />
	        </tabpanel>
	        <tabpanel style="color:#CC0033;overflow: scroll;">
	        	<include
					if="${vm.programType.isCetTvet()}"
					programCetTvetInfo="@load(vm.programCetTvetInfo)"
					src="@load((WebForm.getBundleResourcePath('fragment/test/programCetTvetInfo.zul')))" />
	        </tabpanel>
	        <tabpanel style="color:#CC3300;overflow: scroll;">
	        	<include if="${vm.programType.isShowMainAddress()}"
					addressInfo="@load(vm.programContact)"
					src="@load((WebForm.getBundleResourcePath('fragment/test/address.zul')))" />
			
				<include if="${vm.programType.isShowMainAddressAlter()}"
					addressInfo="@load(vm.alternateProgramContact)"
					src="@load((WebForm.getBundleResourcePath('fragment/test/address.zul')))" />
	        </tabpanel>
	    </tabpanels>
	</tabbox>
</div>
</zk>