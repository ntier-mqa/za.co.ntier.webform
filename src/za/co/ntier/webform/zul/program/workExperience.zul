<?xml version="1.0" encoding="UTF-8"?>

<nodom
	viewModel="@id('vmWorkExperience') @init('za.co.ntier.webform.form.viewmodel.program.WorkExperienceVMWrapper')">

	<hlayout sclass="sectionHeader">
		<label sclass="sectionHeaderTitle"
			value="WORK EXPERIENCE AND VACATION WORK" />
	</hlayout>

	<label value="• VACATION WORK" />

	<div sclass="grid-table grid-table-auto-2">
		<div sclass="grid-cell">
			<label value="Number of learners applying for Vacation Work?" />
		</div>
		<div sclass="grid-cell">
			<textbox value="@bind(vmWorkExperience.program.noOfLearners)"
			onChange="@command('notifyProgramComplete')" />
		</div>
	</div>

	<include
		component="@load(vmWorkExperience.program.vacationContact)"
		applicationProgramVM="@init(vmWorkExperience.applicationProgramVM)"
	    notifyTarget="@init('programComplete')"
		src="@load((WebForm.getBundleResourcePath('component/address.zul')))" />

	<label value="• WORK EXPERIENCE (PRACTICAL TRAINING)" />
	<include
		component="@load(vmWorkExperience.program.disciplines)"
		applicationProgramVM="@init(vmWorkExperience.applicationProgramVM)"
	    notifyTarget="@init('programComplete')"
		src="@load((WebForm.getBundleResourcePath('component/annexureTable.zul')))" />
</nodom>