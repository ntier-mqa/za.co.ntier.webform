<?xml version="1.0" encoding="UTF-8"?>
<?import za.co.ntier.webform.form.WebForm ?>
<?import za.co.ntier.webform.form.bean.ProgramType ?>
<?import za.co.ntier.webform.form.viewmodel.program.ProgramVMWrapper ?>

<?taglib uri="http://www.zkoss.org/dsp/web/core" prefix="c"?>

<div sclass="test" style="height:100%" xmlns:n="native"
		viewModel="@id('vm') @init('za.co.ntier.webform.form.viewmodel.DiscretionaryGrantsApplicationProgramVM')">
	
	<label sclass="formHeader" value="@init(vm.formInfo.formHeader)" />
	
	<tabbox width="100%" vflex="1" id="formTab">
	    <tabs>
	        <tab label="Declaration" />
	        <tab label="Organisation Information" />
	        <tab label="Program" />
	        <tab label="Program Contact" />
	    </tabs>
	    <tabpanels>
	        <tabpanel style="color:#336699">
		        <div sclass="tabContainer">
		        	<div sclass="formContainer">
		        		<include menuContextInfo="@load(vm.menuContextInfo)"
						src="@load((WebForm.getBundleResourcePath('component/generalAppRule.zul')))" />
						
						<include menuContextInfo="@load(vm.menuContextInfo)"
						src="@load((WebForm.getBundleResourcePath('component/employerDeclaration.zul')))" />
		        	</div>
		        	
		        	<div sclass="formBottomPanelFirst">
		        		<button label="Next" 
		        			sclass="icon-on-right"
		        			iconSclass="z-icon-arrow-right"
		        			onClick="@command('nextTab', tab=formTab)"/>
		        	</div>
		        </div>
	        </tabpanel>
	        
	        <tabpanel style="color:#663366;">
		        <div sclass="tabContainer">
		        	<div sclass="formContainer">
		        		<include 
			        		menuContextInfo="@load(vm.menuContextInfo)"
			        		organisationInfo="@load(vm.organisationInfo)"
							src="@load((WebForm.getBundleResourcePath('component/organisationInfo.zul')))" />
		        	</div>
		        	<div sclass="formBottomPanel">
		        		<button label="Prev" 
		        			iconSclass="z-icon-arrow-left"
		        			onClick="@command('prevTab', tab=formTab)"/>
		        		
		        		<button label="Next" 
		        			sclass="icon-on-right"
		        			iconSclass="z-icon-arrow-right"
		        			onClick="@command('nextTab', tab=formTab)"/>
		        	</div>
		        </div>
	        </tabpanel>
	        
	        <tabpanel style="color:#CC0033;overflow: scroll;">
		        <div sclass="tabContainer">
		        	<div sclass="formContainer">
			        	<include
							if="${vm.programType.isCetTvet()}"
							programCetTvetInfo="@load(vm.programCetTvetInfo)"
							src="@load((WebForm.getBundleResourcePath('component/programCetTvetInfo.zul')))" />
						<include
							if="${!vm.programType.isCetTvet()}"
							programInfo="@load(vm.programInfo)"
							src="@load((WebForm.getBundleResourcePath('component/programInfo.zul')))" />
						
						<include
							if="${vm.programType eq ProgramType.CANDIDACY}"
							program="@load(vm.candidacy)"
							src="@load((WebForm.getBundleResourcePath('program/candidacy.zul')))" />
						
						<include
							if="${vm.programType eq ProgramType.INTERNSHIP}"
							program="@load(vm.internship)"
							src="@load((WebForm.getBundleResourcePath('program/internship.zul')))" />
						
						<include
							if="${vm.programType eq ProgramType.EXPERIENCE}"
							program="@load(vm.workExperience)"
							src="@load((WebForm.getBundleResourcePath('program/workExperience.zul')))" />	
											
					</div>
					<div sclass="formBottomPanel">
		        		<button label="Prev" 
		        			iconSclass="z-icon-arrow-left"
		        			onClick="@command('prevTab', tab=formTab)"/>
		        		
		        		<button label="Next"
		        			sclass="icon-on-right"
		        			iconSclass="z-icon-arrow-right"
		        			onClick="@command('nextTab', tab=formTab)"/>
		        	</div>
		        </div>
	        </tabpanel>
	        <tabpanel style="color:#CC3300;overflow: scroll;">
	        	<div sclass="tabContainer">
		        	<div sclass="formContainer">
				        <include if="${vm.programType.isShowMainAddress()}"
							addressInfo="@load(vm.programContact)"
							src="@load((WebForm.getBundleResourcePath('component/address.zul')))" />
					
						<include if="${vm.programType.isShowMainAddressAlter()}"
							addressInfo="@load(vm.alternateProgramContact)"
							src="@load((WebForm.getBundleResourcePath('component/address.zul')))" />	
					</div>
					<div sclass="formBottomPanel">
		        		<button label="Prev" 
		        			iconSclass="z-icon-arrow-left"
		        			onClick="@command('prevTab', tab=formTab)"/>
		        		
		        		<button label="Submit" 
		        			iconSclass="z-icon-gear"
		        			sclass="icon-on-right"
		        			onClick="@command('submitApplication')"/>
		        	</div>
		        </div>
	        </tabpanel>
	    </tabpanels>
	</tabbox>
	
	<window title="Done" width="300px" mode="modal" position="center,center" visible="@load(vm.showDialog)">
    
		<div class="modal-body">
        <label value="The application form has been created."/>
      </div>
      <div class="modal-footer">
        <button sclass="btn btn-primary"
        label="OK"
        onClick="@command('closeDialog')" />
      </div>
   		
    </window>
</div>
