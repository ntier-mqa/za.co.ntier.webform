<?xml version="1.0" encoding="UTF-8"?>

<nodom xmlns:n="native"
	viewModel="@id('vmTabButton') @init('za.co.ntier.webform.sdr.component.tab.viewmodel.TabButtonVM')">

	<div sclass="formBottomPanel">
			
		<button
			visible="@load(vmTabButton.supportDeleteApp and vmTabButton.showDel)"
			label="@init(vmTabButton.deleteLabel)" iconSclass="z-icon-xmark"
			onClick="@command('deleteApp')" />
		
		
		<button 
			visible="@load(vmTabButton.showPrev)"
			label="Back" 
			iconSclass="z-icon-arrow-left"
			onClick="@command('prevTab')" 
			/>

		<button
			visible="@load(vmTabButton.showSaveApp)"			
		  	label="Save &amp; Exit" sclass="icon-on-right"
			iconSclass="z-icon-floppy-disk"
			onClick="@command('saveApp')" />

		<button
			visible="@load(vmTabButton.showNext)" 
			label="Next" sclass="icon-on-right"
			iconSclass="z-icon-arrow-right"
			onClick="@command('nextTab')" />
		
		<button
			visible="@load(vmTabButton.showSubmitApp)"
			label="Submit Application"
			iconSclass="z-icon-gear" sclass="icon-on-right"
	    	onClick="@command('submitApp')" />
	</div>
</nodom>